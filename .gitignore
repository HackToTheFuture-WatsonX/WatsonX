# -- Python --------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
*.pdb
*.egg-info/
dist/
.eggs/
venv/
.venv/
env/
*.egg

# -- Sensitive credentials - NEVER commit these --------------------------------
# Box JWT private key file (contains an encrypted RSA private key + passphrase)
box_jwt_config.json

# App config files contain live Box secrets + ICA session cookies. NEVER commit.
# Commit a config.example.json / config.template.json instead (see !exceptions below).
config.json
**/config.json
!**/config.example.json
!**/config.template.json


# -- PyInstaller build artifacts -----------------------------------------------
*.spec
build/
*.exe
.bob/

# -- OS / editor files ---------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/
*.swp
*.swo

# -- Local credentials backup - never push this --
MY_CREDENTIALS_BACKUP.txt
TRACKING_DB_BACKUP.txt

# -- Runtime / generated files - never push these --
extractor.log
*.log
tracking_db.json
*.bak
*.bak2

# -- Local Folder (synced PDFs, extracted reports, archives) -------------------
PDF Extractor V2/Local Folder/
PDF Extractor/Local Folder/

# -- ICA cookie parser (local tool only) --------------------------------------
ICA Cookie Parser/


# -- System files (local tool only)
node_modules/
dist/
build/
.cline
.claude
pdf_extractor_v3.db*

# -- PDF Extractor V3 build artifacts (never commit generated output) ----------
# PyInstaller-bundled backend (~1000 files: DLLs, tzdata, dist-info)
PDF Extractor V3/electron/resources/
# Vite-built renderer output
PDF Extractor V3/electron/renderer/
# Electron-builder packaged output
PDF Extractor V3/dist/
PDF Extractor V3/electron/dist/
# Backend build staging + generated icon
PDF Extractor V3/backend/build/
PDF Extractor V3/backend/dist/
# Runtime port file written by main.js on launch
PDF Extractor V3/.v3_port
**/.v3_port
# asar extraction check dir
PDF Extractor V3/electron/_asar_check/
# Local frontend env (points at a dev port only, but keep local)
PDF Extractor V3/frontend/.env.local

